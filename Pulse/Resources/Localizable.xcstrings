    "Subscriptions" : {
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abonelikler"
          }
        }
      }
    },
    "Subscriptions auto-renew at the end of each billing period unless cancelled at least 24 hours before the end of the current period. Payment is charged to your Apple ID. Manage or cancel anytime in your App Store account." : {
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abonelikler her fatura dönemi sonunda otomatik yenilenir; mevcut dönemin bitiminden en az 24 saat önce iptal etmelisin. Ödeme Apple ID'ne yansıtılır. App Store hesabından istediğin zaman yönet veya iptal et."
          }
        }
      }
    },
    "Subscriptions auto-renew at the end of each billing period unless cancelled at least 24 hours before. Manage or cancel anytime in your App Store account. Payment is charged to your Apple ID. By continuing you agree to the Terms and Privacy Policy below." : {
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abonelikler iptal edilmediği sürece her fatura dönemi sonunda otomatik yenilenir; en az 24 saat öncesinden iptal etmelisin. App Store hesabından istediğin zaman yönet veya iptal et. Ödeme Apple ID'ne yansıtılır. Devam ettiğinde aşağıdaki Şartlar ve Gizlilik Politikası'nı kabul etmiş olursun."
          }
        }
      }
    },
